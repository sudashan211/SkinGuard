# SkinGuard Test Configuration
# Copy this file to .env and fill in your database credentials

# Database Connection for Property-Based Tests
# This should point to your Supabase PostgreSQL database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Alternative: Use local PostgreSQL for testing
# DATABASE_URL=postgresql://postgres:password@localhost:5432/skinguard_test

# Note: Property-based tests require a real database connection
# to test database constraints and referential integrity
