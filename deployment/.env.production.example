# SkinGuard Production Environment Configuration
# Copy this file to .env.production and fill in your production values
# NEVER commit .env.production to version control!

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
API_VERSION=v1

# ============================================================================
# DATABASE - SUPABASE PRODUCTION
# ============================================================================
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_KEY=your-production-anon-key
SUPABASE_SERVICE_KEY=your-production-service-role-key
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-production-project.supabase.co:5432/postgres

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-production-secret-key-min-32-chars-CHANGE-THIS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# STORAGE - SUPABASE STORAGE
# ============================================================================
STORAGE_BUCKET=medical-images-prod
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png
MIN_IMAGE_WIDTH=512
MIN_IMAGE_HEIGHT=512

# ============================================================================
# CDN - CLOUDFRONT
# ============================================================================
CLOUDFRONT_DOMAIN=d1234567890abc.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ============================================================================
# EMAIL - SENDGRID
# ============================================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=noreply@skinguard.com
FROM_NAME=SkinGuard
SUPPORT_EMAIL=support@skinguard.com

# ============================================================================
# VIDEO CONSULTATION - TWILIO
# ============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your-twilio-api-secret
TWILIO_VIDEO_ROOM_TYPE=group
TWILIO_MAX_PARTICIPANTS=2

# ============================================================================
# GOOGLE MAPS API
# ============================================================================
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_MAPS_REGION=US

# ============================================================================
# AI MODELS
# ============================================================================
MODEL_CACHE_DIR=/opt/models
NSFW_MODEL_PATH=/opt/models/nsfw_detector
SWIN_MODEL_PATH=/opt/models/swin_transformer
EFFICIENTNET_MODEL_PATH=/opt/models/efficientnet_b7

# Model inference settings
USE_GPU=true
GPU_DEVICE_ID=0
MODEL_BATCH_SIZE=1
MODEL_TIMEOUT_SECONDS=30

# NSFW Filter thresholds
NSFW_THRESHOLD=0.35
NON_SKIN_THRESHOLD=0.8

# ============================================================================
# SECURITY
# ============================================================================
# CORS settings
CORS_ORIGINS=https://skinguard.com,https://www.skinguard.com
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10

# Security headers
ENABLE_HSTS=true
ENABLE_CSP=true
ENABLE_X_FRAME_OPTIONS=true

# ============================================================================
# MONITORING - SENTRY
# ============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# REDIS CACHE (Optional)
# ============================================================================
REDIS_URL=redis://your-redis-host:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_TTL_SECONDS=3600
ENABLE_REDIS_CACHE=true

# ============================================================================
# PERFORMANCE
# ============================================================================
# API settings
API_WORKERS=4
API_TIMEOUT_SECONDS=120
API_MAX_CONNECTIONS=1000
API_KEEPALIVE_TIMEOUT=5

# Image processing
IMAGE_PROCESSING_TIMEOUT=30
MAX_CONCURRENT_ANALYSES=10

# ============================================================================
# NOTIFICATIONS
# ============================================================================
# Email notification settings
ENABLE_EMAIL_NOTIFICATIONS=true
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_SECONDS=5

# Push notifications (optional)
ENABLE_PUSH_NOTIFICATIONS=false
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# ============================================================================
# ANALYTICS
# ============================================================================
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90
ENABLE_USAGE_TRACKING=true

# ============================================================================
# BACKUP
# ============================================================================
ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=skinguard-backups-prod

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_VIDEO_CONSULTATIONS=true
ENABLE_EMERGENCY_REFERRAL=true
ENABLE_MULTI_LANGUAGE=true
ENABLE_PWA=true
ENABLE_TELEMEDICINE=true

# ============================================================================
# COMPLIANCE
# ============================================================================
ENABLE_AUDIT_LOGGING=true
ENABLE_GDPR_COMPLIANCE=true
ENABLE_HIPAA_COMPLIANCE=true
DATA_RETENTION_DAYS=2555  # 7 years for medical records

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# WhatsApp Business API (optional)
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_BUSINESS_ID=your-business-id

# Payment gateway (future feature)
STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# ============================================================================
# DEPLOYMENT INFO
# ============================================================================
DEPLOYMENT_DATE=2026-02-12
VERSION=1.0.0
BUILD_NUMBER=1
COMMIT_SHA=abc123def456
